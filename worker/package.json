{
  "name": "@irodori/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "db:apply:local": "wrangler d1 execute irodori --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute irodori --remote --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.5",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.84.0"
  }
}
